# 复制此文件为 .env 并填写真实值
# cp .env.example .env

# ========== 数据库配置 ==========
# 完整的数据库连接 URL
DATABASE_URL=postgres://user:password@host:5432/dbname

# 生产环境 PostgreSQL 配置（仅 docker-compose.prod.yml 使用）
POSTGRES_DB=rfc2cn
POSTGRES_USER=rfc2cn
POSTGRES_PASSWORD=your_secure_password_here

# ========== 后端配置 ==========
RUST_LOG=info
SERVER_HOST=0.0.0.0
SERVER_PORT=8080

# AI 配置
AI_PROVIDER=ollama
OLLAMA_URL=http://host.docker.internal:11434

# ========== 前端配置 ==========
NEXT_PUBLIC_API_URL=http://localhost:33101
